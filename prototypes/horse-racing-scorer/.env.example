# Copy to .env and fill in.

# Where the SQLite file lives. Defaults to ./data/comp.db if unset.
# DB_PATH=./data/comp.db

# Set this to enable the /admin section. Pick something unguessable.
ADMIN_PASSWORD=

# Credentials for theracingapi.com (free plan covers UK/IRE results).
# Sign up at https://www.theracingapi.com/ and grab them from your dashboard.
# Without these, /admin/sync will refuse to run.
RACING_API_USERNAME=
RACING_API_PASSWORD=
