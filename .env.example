# =============================================================================
# AI Venture Studio Workspace — Environment Variables
# =============================================================================
# Copy to .env and fill in your values.

# --- AI ---
ANTHROPIC_API_KEY=sk-ant-...       # Used for research and implementation planning

# --- Database ---
DATABASE_URL=postgresql://user:pass@localhost:5432/ai_venture_studio

# --- GitHub ---
GITHUB_TOKEN=ghp_...               # Token with access to allowed target repos

# --- Control API ---
CONTROL_API_BASE_URL=https://control.internal
CONTROL_API_TOKEN=change-me        # Shared secret for the future OpenClaw bridge

# --- Slack approvals ---
SLACK_BOT_TOKEN=xoxb-...           # Bot token used for posting founder alerts and approval requests
SLACK_APPROVER_IDS=U12345,U67890   # Comma-separated Slack user IDs allowed to approve risky actions. Use * to allow any Slack user who can reach the approval flow.
SLACK_DEFAULT_CHANNEL_ID=#virtual-org-chief   # Fallback Slack channel for founder alerts and approvals
SLACK_DISPATCH_INTERVAL_SECONDS=10 # How often the Slack dispatcher checks for new alerts

# --- Execution Timing ---
IMPLEMENT_TIMEOUT_SECONDS=300      # How long implementation runs are allowed to take
LEASE_SECONDS=420                  # How long a claimed task stays reserved before it is treated as stale

# --- Target Repos ---
# List allowed repos as owner/name, separated by commas.
# This repo is not the default target. Leave blank to disable automated code changes.
ALLOWED_REPOS=

# --- Tempa Sales Agent ---
# Safe defaults keep live email fully off until explicitly enabled.
SALES_AGENT_ENABLED=false
SALES_SEND_MODE=dry_run
SALES_KILL_SWITCH=true
SALES_AGENT_ID=
SALES_DAILY_NEW_PROSPECT_LIMIT=5
SALES_ALLOWED_RECIPIENT_COUNTRIES=US
SALES_WORKER_POLL_INTERVAL_SECONDS=60
SALES_PUBLIC_API_HOST=127.0.0.1
SALES_PUBLIC_API_PORT=8091

APOLLO_API_KEY=
AGENTMAIL_API_KEY=
AGENTMAIL_SENDER_DOMAIN=
AGENTMAIL_WEBHOOK_SECRET=
CONTROL_PUBLIC_BASE_URL=

TEMPA_SALES_STRATEGY_URL=
TEMPA_SALES_STRATEGY_ALLOWED_HOSTS=
TEMPA_SALES_STRATEGY_TOKEN=
TEMPA_DEMO_BOOKING_URL=
SALES_SENDER_NAME=Max
SALES_POSTAL_ADDRESS=
SALES_UNSUBSCRIBE_BASE_URL=
SALES_WEBHOOK_MAX_BODY_BYTES=262144
