# =============================================================================
# Virtual Org — Environment Variables
# =============================================================================
# Copy to .env and fill in your values

# --- Slack Bot (create at https://api.slack.com/apps) ---
SLACK_BOT_TOKEN=xoxb-...           # Bot User OAuth Token
SLACK_APP_TOKEN=xapp-...           # Socket Mode token (no public URL needed)
SLACK_SIGNING_SECRET=...

# --- AI ---
ANTHROPIC_API_KEY=sk-ant-...       # Claude for triage, research, implementation planning

# --- Database ---
DATABASE_URL=postgresql://user:pass@localhost:5432/virtual_org

# --- GitHub (for creating branches + PRs) ---
GITHUB_TOKEN=ghp_...               # Personal access token with repo scope

# --- Notifications ---
# Bot DMs you directly by default. Set this to also post to a channel.
SLACK_NOTIFY_CHANNEL=               # Optional: channel ID for progress updates

# --- Worker ---
POLL_INTERVAL_SECONDS=30            # How often worker checks for new tasks
TRIAGE_INTERVAL_SECONDS=300         # How often triage runs (5 min)
IMPLEMENT_TIMEOUT_SECONDS=300       # How long Claude Code gets before timing out

# --- Content Pipeline ---
CONTENT_OWNER_SLACK_USER=U12345678       # Your Slack user ID (find in your Slack profile)
CONTENT_INTERVIEW_DAY=monday             # Day of week for weekly interview
CONTENT_INTERVIEW_HOUR=10                # Hour (24h format) to start the interview

# --- Target Repos (comma-separated, agent can work on these) ---
ALLOWED_REPOS=maxshepcross/tempa
